BOT_TOKEN=your_bot_token_here
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/coursesbot
SUPER_ADMIN_IDS=123456789,987654321
REFERRAL_BONUS=20000
MIN_WITHDRAWAL=50000

# Tasdiqlangan cheklar yuboriladigan maxfiy kanal ID
# Bot o'sha kanalda admin bo'lishi shart!
RECEIPTS_CHANNEL_ID=-1001234567890

# Railway da WEBHOOK_URL = https://YOUR_APP.up.railway.app
# Bo'sh qolsa — polling rejimi (lokal ishlab chiqish)
WEBHOOK_URL=https://your-app.up.railway.app
WEBHOOK_SECRET=your_secret_token_here

# Railway avtomatik beradi, o'zgartirmang
PORT=8080
